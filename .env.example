# Copy to .env and fill in. main.py does NOT auto-load .env — export the
# variables in your shell, or pass the file to Docker:
#   docker run --rm --env-file .env hybrid-router-agent

FIREWORKS_API_KEY=fw-xxxxxxxxxxxxxxxx

# Injected by the scoring harness (set locally only to simulate it):
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1  # ALL remote calls go through it
# ALLOWED_MODELS=accounts/fireworks/models/deepseek-v4-pro,accounts/fireworks/models/kimi-k2p6
# REMOTE_MODEL_PREFERENCE=deepseek-v4-pro   # tie-breaker within ALLOWED_MODELS
# RUN_DEADLINE_S=540        # stop waiting + write results this many s after start
# REMOTE_CONCURRENCY=8      # parallel remote calls in the task pool

# Kickoff-day overrides (defaults live in config.py):
# LOCAL_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
# REMOTE_MODEL_NAME=accounts/fireworks/models/deepseek-v4-pro   # dev fallback when ALLOWED_MODELS unset
# CONFIDENCE_THRESHOLD=0.55
# LOGPROB_CONFIDENCE_THRESHOLD=0.4   # local model's self-confidence gate; 0 disables
# ENABLE_ESCALATION=1
# LOCAL_MAX_NEW_TOKENS=512
# REMOTE_MAX_TOKENS=4096
# REQUEST_TIMEOUT_S=120     # read timeout; must cover a full remote generation
# CONNECT_TIMEOUT_S=10
# AGENT_MOCK=1
